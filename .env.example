# Supermemory API key (required)
SPOON_SUPERMEMORY_API_KEY=

# API key for Spoon endpoints (recommended for any network exposure)
SPOON_API_KEY=

# Environment: development | production (disables /docs; requires API key + token encryption)
SPOON_ENV=development

# Base URL of this app (default: http://localhost:8000)
SPOON_APP_URL=http://localhost:8000

# Supermemory container tag for grouping documents
SPOON_CONTAINER_TAG=

# --- Security ---

# Encrypt OAuth tokens at rest (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
SPOON_TOKEN_ENCRYPTION_KEY=

# OAuth CSRF state backend: memory | redis
SPOON_OAUTH_STATE_BACKEND=memory
SPOON_REDIS_URL=redis://localhost:6379/0

# Disable rate limiting (enabled by default)
SPOON_RATE_LIMIT_ENABLED=true

# Rate limit storage backend: memory | redis
# Use "redis" (with SPOON_REDIS_URL set) if running multiple Uvicorn workers
# or replicas — the "memory" backend does not share counters across processes.
SPOON_RATE_LIMIT_BACKEND=memory

# Trust the X-Forwarded-For header for rate-limiting/client identification.
# Only enable this if Spoon sits behind a reverse proxy that overwrites this
# header itself — otherwise any client can spoof it to bypass rate limits.
SPOON_TRUST_PROXY_HEADERS=false

# Comma-separated list of allowed browser origins for CORS. Leave empty
# (default) to keep cross-origin browser requests blocked entirely.
SPOON_CORS_ALLOWED_ORIGINS=

# Resource limits
SPOON_MAX_DOCUMENTS_PER_SYNC=5000
SPOON_MAX_FILE_BYTES=25000000
SPOON_SYNC_SINCE_DAYS=
SPOON_MAX_SLACK_CHANNELS=500
SPOON_MAX_SLACK_MESSAGES_PER_CHANNEL=2000

# --- Notion ---

SPOON_NOTION_API_KEY=
SPOON_NOTION_CONNECTION_CLIENT_ID=
SPOON_NOTION_CONNECTION_SECRET_ID=
SPOON_NOTION_CONNECTION_AUTHORIZATION_URL=

# --- Linear ---

SPOON_LINEAR_API_KEY=

# --- Google (Drive + Gmail) ---

# Service account JSON path (preferred name)
SPOON_GDRIVE_SERVICE_ACCOUNT_PATH=
# Deprecated alias — use SPOON_GDRIVE_SERVICE_ACCOUNT_PATH
SPOON_GDRIVE_API_KEY=

SPOON_GDRIVE_CONNECTION_CLIENT_ID=
SPOON_GDRIVE_CONNECTION_SECRET_ID=
SPOON_GDRIVE_CONNECTION_AUTHORIZATION_URL=

# --- Outlook ---

SPOON_OUTLOOK_CONNECTION_CLIENT_ID=
SPOON_OUTLOOK_CONNECTION_SECRET_ID=
SPOON_OUTLOOK_CONNECTION_AUTHORIZATION_URL=

# --- Slack ---

SPOON_SLACK_BOT_TOKEN=
SPOON_SLACK_APP_ID=
SPOON_SLACK_CLIENT_ID=
SPOON_SLACK_CLIENT_SECRET=
SPOON_SLACK_SIGNING_SECRET=
SPOON_SLACK_VERIFICATION_TOKEN=
SPOON_SLACK_CONNECTION_AUTHORIZATION_URL=

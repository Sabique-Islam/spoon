# Supermemory API key (required)
SPOON_SUPERMEMORY_API_KEY=

# Base URL of this app (default: http://localhost:8000)
SPOON_APP_URL=http://localhost:8000

# Supermemory container tag for grouping documents
SPOON_CONTAINER_TAG=

# --- Notion ---

# Notion internal integration token (optional fallback — skips OAuth)
SPOON_NOTION_API_KEY=

# Notion OAuth credentials (for public integration flow)
SPOON_NOTION_CONNECTION_CLIENT_ID=
SPOON_NOTION_CONNECTION_SECRET_ID=

# OAuth redirect URI registered in Notion developer portal
# Falls back to {SPOON_APP_URL}/api/v1/auth/notion/callback if unset
SPOON_NOTION_CONNECTION_AUTHORIZATION_URL=

# --- Linear ---

# Linear personal API key (from Linear → Settings → Security & access)
SPOON_LINEAR_API_KEY=

# --- Google (Drive + Gmail) ---

# Service account JSON file path (optional fallback — skips OAuth)
# Example: /path/to/service-account.json
SPOON_GDRIVE_API_KEY=

# Google OAuth credentials (from Google Cloud Console)
# Used for both Drive and Gmail sync. Enable Drive API + Gmail API on the project.
SPOON_GDRIVE_CONNECTION_CLIENT_ID=
SPOON_GDRIVE_CONNECTION_SECRET_ID=

# OAuth redirect URI registered in Google Cloud Console
# Falls back to {SPOON_APP_URL}/api/v1/auth/gdrive/callback if unset
SPOON_GDRIVE_CONNECTION_AUTHORIZATION_URL=

# --- Slack ---

# Bot token fallback (optional — skips OAuth). From Slack app OAuth & Permissions.
# Grant the same read scopes listed in app/auth/slack_oauth.py on the app.
SPOON_SLACK_BOT_TOKEN=

# Slack app credentials (from api.slack.com → Your App → Basic Information / OAuth)
SPOON_SLACK_APP_ID=
SPOON_SLACK_CLIENT_ID=
SPOON_SLACK_CLIENT_SECRET=
SPOON_SLACK_SIGNING_SECRET=
SPOON_SLACK_VERIFICATION_TOKEN=

# OAuth redirect URI registered in Slack app OAuth settings
# Falls back to {SPOON_APP_URL}/api/v1/auth/slack/callback if unset
SPOON_SLACK_CONNECTION_AUTHORIZATION_URL=
